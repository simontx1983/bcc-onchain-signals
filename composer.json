    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "kornrunner/keccak": "^1.1",
        "simplito/elliptic-php": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "BCC\\Onchain\\": "app/"
        }
